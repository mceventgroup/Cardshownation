{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "NEXT_PUBLIC_APP_URL",
        "ADMIN_SETUP_CODE",
        "ADMIN_SESSION_SECRET",
        "MODERATOR_SESSION_SECRET",
        "PROMOTER_SESSION_SECRET",
        "USER_SESSION_SECRET",
        "CRON_SECRET",
        "RESEND_API_KEY",
        "BLOB_READ_WRITE_TOKEN",
        "FLOORPLANNER_SESSION_SECRET",
        "FLOORPLANNER_ADMIN_PASSWORD",
        "CSN_DATA_MODE",
        "NODE_ENV"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:deploy": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    }
  }
}
