generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma-client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  FAN
  MODERATOR
  ORGANIZER
  ADMIN
}

enum ShowStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SourceType {
  MANUAL
  SUBMITTED
  IMPORTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                String     @id @default(cuid())
  name              String?
  email             String     @unique
  phone             String?
  city              String?
  state             String?
  passwordHash      String?
  role              UserRole   @default(FAN)
  emailVerifiedAt   DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  savedShows        SavedShow[]
  reports           ShowReport[]
  moderatedSubmissions ShowSubmission[] @relation("SubmissionReviewer")
  subscriptions     UserStateSubscription[]
  auditLogs         AuditLog[] @relation("AuditActor")
  organizer         Organizer?
  verificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model RateLimitBucket {
  id           String   @id @default(cuid())
  scope        String
  key          String
  attemptCount Int      @default(0)
  windowStart  DateTime
  blockedUntil DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([scope, key])
  @@index([blockedUntil])
}

model Organizer {
  id           String   @id @default(cuid())
  name         String
  email        String?
  websiteUrl   String?
  facebookUrl  String?
  instagramUrl String?
  verified     Boolean  @default(false)
  userId       String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  shows        Show[]
  approvals    OrganizerApproval[]
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model OrganizerApproval {
  id                String   @id @default(cuid())
  organizerId       String
  city              String
  state             String
  autoApprove       Boolean  @default(false)
  reviewEvery       Int      @default(4)
  approvedShowCount Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@unique([organizerId, city, state])
  @@index([state, city])
}

model Venue {
  id          String   @id @default(cuid())
  name        String
  address1    String
  address2    String?
  city        String
  state       String   // 2-letter state code e.g. "TX"
  postalCode  String?
  latitude    Float?
  longitude   Float?
  parkingInfo String?
  loadInInfo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shows       Show[]
  floorplans  ShowFloorplan[]

  @@unique([name, city, state], name: "name_city_state")
  @@index([state])
  @@index([city, state])
}

model Show {
  id                  String     @id @default(cuid())
  title               String
  slug                String     @unique
  description         String?
  status              ShowStatus @default(PENDING)
  sourceType          SourceType @default(SUBMITTED)
  timezone            String     @default("America/Chicago")
  startDate           DateTime
  endDate             DateTime
  startTimeLabel      String?    // e.g. "9:00 AM"
  endTimeLabel        String?    // e.g. "4:00 PM"
  city                String
  state               String     // 2-letter code
  isFree              Boolean    @default(false)
  admissionPrice      String?
  admissionNotes      String?
  tableCount          Int?
  vendorDetails       String?
  estimatedAttendance Int?
  flyerImageUrl       String?
  websiteUrl          String?
  facebookUrl         String?
  ticketUrl           String?
  parkingInfo         String?
  loadInInfo          String?
  venueNotes          String?
  categories          String[]
  lastVerifiedAt      DateTime?
  expiresAt           DateTime?
  viewCount           Int        @default(0)
  favoriteCount       Int        @default(0)
  featuredRank        Int?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  organizerId         String?
  venueId             String?

  organizer Organizer? @relation(fields: [organizerId], references: [id])
  venue     Venue?     @relation(fields: [venueId], references: [id])
  savedBy   SavedShow[]
  reports   ShowReport[]
  tags      ShowTag[]
  floorplans ShowFloorplan[]

  @@index([state, status, startDate])
  @@index([city, state, status])
  @@index([slug])
  @@index([startDate, status])
  @@index([status, featuredRank])
}

model ShowFloorplan {
  id         String   @id @default(cuid())
  showId      String
  venueId     String?
  name        String
  dataJson    Json
  revision    Int      @default(1)
  tableCount  Int      @default(0)
  vendorCount Int      @default(0)
  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  show  Show  @relation(fields: [showId], references: [id], onDelete: Cascade)
  venue Venue? @relation(fields: [venueId], references: [id], onDelete: SetNull)

  @@index([showId, updatedAt])
  @@index([venueId])
  @@unique([showId, name])
}

model SavedShow {
  id        String   @id @default(cuid())
  userId    String
  showId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  show Show @relation(fields: [showId], references: [id], onDelete: Cascade)

  @@unique([userId, showId])
}

model ShowSubmission {
  id             String           @id @default(cuid())
  submitterName  String
  submitterEmail String
  payloadJson    Json
  status         SubmissionStatus @default(PENDING)
  notes          String?
  reviewerId     String?
  reviewerRole   UserRole?
  reviewedShowId String?          // linked Show id after approval
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  reviewer User? @relation("SubmissionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
}

model ShowReport {
  id        String   @id @default(cuid())
  showId    String
  userId    String?
  reason    String
  details   String?
  createdAt DateTime @default(now())

  show Show  @relation(fields: [showId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ShowTag {
  id     String @id @default(cuid())
  showId String
  label  String

  show Show @relation(fields: [showId], references: [id], onDelete: Cascade)

  @@unique([showId, label])
  @@index([label])
}

model ImportLog {
  id           String   @id @default(cuid())
  source       String   // "eventbrite", "facebook", etc.
  imported     Int
  skipped      Int
  errors       Int
  errorDetails String?
  createdAt    DateTime @default(now())

  @@index([source, createdAt])
}

model UserStateSubscription {
  id           String   @id @default(cuid())
  userId       String
  stateCode    String
  emailEnabled Boolean  @default(true)
  textEnabled  Boolean  @default(false)
  pushEnabled  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stateCode])
  @@index([stateCode])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  UserRole?
  action     String
  targetType String
  targetId   String?
  details    Json?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@index([actorId, createdAt])
}

// State directory table — seeded once, drives /card-shows/[state] pages
model State {
  id       String  @id // 2-letter code: "TX", "CA", etc.
  name     String
  slug     String  @unique // "texas", "california", etc.
  seoBlurb String? // short intro paragraph for state pages
}
