{
  "name": "card-show-nation",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "tsc --noEmit -p apps/web/tsconfig.json",
    "test:web": "tsx --tsconfig apps/web/tsconfig.json --test apps/web/lib/moderation.test.ts apps/web/lib/flyers.test.ts apps/web/lib/users.test.ts",
    "secrets:scan": "powershell -ExecutionPolicy Bypass -File ./scripts/scan-secrets.ps1",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "db:studio": "cd packages/db && npx prisma studio"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  },
  "overrides": {
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@typescript-eslint/type-utils": "7.18.0",
    "@typescript-eslint/typescript-estree": "7.18.0",
    "@typescript-eslint/utils": "7.18.0",
    "next": {
      "postcss": "8.5.10"
    },
    "postcss": "8.5.10",
    "uuid": "14.0.0"
  },
  "packageManager": "npm@10.8.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.7.0",
    "resend": "^6.12.2",
    "ws": "^8.21.0"
  }
}
